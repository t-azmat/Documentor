# Python NLP service deployment variables
#
# Render provides PORT automatically. Keep PORT only for local testing.

PORT=5001

# Free-tier friendly defaults
ENABLE_AI_CITATION_MATCHING=false
FORMATTING_ENGINE_LOCAL_ONLY=true
FORMATTING_ENGINE_USE_AI=false

# Optional: point to a deployed trained grammar checkpoint.
# The checkpoint directory must contain config.json and model weights.
GRAMMAR_MODEL_PATH=

# Optional if you enable AI formatting features.
GROQ_API_KEY=
