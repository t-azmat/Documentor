# Server Configuration
PORT=5000
NODE_ENV=development
BODY_PARSER_LIMIT=25mb

# Database
# Local example:
# MONGODB_URI=mongodb://127.0.0.1:27017/documentor
# Production example:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/documentor?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://tahamalik259_db_user:4RkcuzOndzAumqCc@cluster0.shmeana.mongodb.net/?appName=Cluster0

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=7d

# Frontend URLs
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,https://documentor-one.vercel.app
# Comma-separated regular expressions for preview deployments.
FRONTEND_ORIGIN_PATTERNS=^https:\/\/documentor-[a-z0-9-]+-t-azmats-projects\.vercel\.app$

# Python NLP service
PYTHON_NLP_URL=http://localhost:5001
PYTHON_GRAMMAR_SERVICE_URL=http://localhost:5001
PYTHON_JOBS_DIR=

# Email Configuration (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Stripe Payment
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Formatting engine defaults
FORMATTING_ENGINE_LOCAL_ONLY=false
FORMATTING_ENGINE_USE_AI=true
FORMATTING_ENGINE_EXTRACTOR=docling
FORMATTING_ENGINE_USE_DOCUMENT_CHUNKER=auto
FORMATTING_ENGINE_PRESERVE_SOURCE_FORMAT=true
FORMATTING_ENGINE_CODEGEN_USE_AI=false
FORMATTING_STANDARD_GENERATE_LATEX=false
FORMATTING_LARGE_DOC_WORD_THRESHOLD=20000
STATEFUL_CHUNK_TARGET_WORDS=2000
FORMATTING_ENGINE_PREVIEW_MAX_SECTIONS=80
FORMATTING_ENGINE_PREVIEW_MAX_PARAGRAPHS_PER_SECTION=80

# Groq AI Models (optional)
GROQ_API_KEY=
GROQ_OUTLINE_RECONSTRUCTOR=true
GROQ_CHAPTER_LAYOUT=false
GROQ_LAYOUT_MODELS=llama-3.1-8b-instant,openai/gpt-oss-120b
GROQ_CODEGEN_MODELS=llama-3.1-8b-instant
GROQ_LAYOUT_MAX_PAYLOAD_BYTES=250000
GROQ_CODEGEN_MAX_PAYLOAD_BYTES=90000
GROQ_LAYOUT_MAX_AI_CHAPTERS=6
GROQ_LAYOUT_MIN_PARAGRAPHS_FOR_AI=2
GROQ_HEADING_CANDIDATE_MAX_CHARS=140
GROQ_HEADING_CANDIDATE_MAX_WORDS=14
GROQ_REQUEST_INTERVAL_SECONDS=2
GROQ_RATE_LIMIT_RETRIES=2
GROQ_RATE_LIMIT_BACKOFF_SECONDS=10
GROQ_RATE_LIMIT_MAX_SLEEP_SECONDS=45

# Nougat OCR (optional)
NOUGAT_MODEL=0.1.0-small
NOUGAT_CHECKPOINT=
NOUGAT_PAGES=
NOUGAT_TIMEOUT_SECONDS=900
NOUGAT_NO_SKIPPING=false
NOUGAT_COMMAND=

# Admin Bootstrap
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@documentor.com
ADMIN_PASSWORD=Admin123!ChangeMe
ADMIN_STATUS=active
ADMIN_RESET_PASSWORD_ON_START=false

# OAuth Secrets (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
